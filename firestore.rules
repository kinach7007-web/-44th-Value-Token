rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (e.g., user-1)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - avatar: string (required)
    //   - cumulativeValue: number (required)
    //   - unconfirmedValue: number (required)
    //   - level: number (required)
    //   - balance: number (required)
    //
    // Collection: transactions
    // Document ID: transactionId (auto-generated)
    // Fields:
    //   - id: string (required)
    //   - fromId: string (required)
    //   - toId: string (required)
    //   - fromName: string (required)
    //   - toName: string (required)
    //   - amount: number (required)
    //   - note: string (required)
    //   - timestamp: timestamp/number (required)
    //   - type: string (required)
    //   - confirmed: boolean (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let userDoc = request.auth != null ? get(/databases/$(database)/documents/users/$(request.auth.uid)) : null;
      return request.auth != null &&
        ((userDoc != null && userDoc.data.role == 'admin') ||
          (request.auth.token.email == "kinach7007@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.avatar is string &&
             data.cumulativeValue is number &&
             data.unconfirmedValue is number &&
             data.level is number &&
             data.balance is number;
    }

    function isValidTransaction(data) {
      return data.id is string &&
             data.fromId is string &&
             data.toId is string &&
             data.fromName is string &&
             data.toName is string &&
             data.amount is number && data.amount > 0 &&
             data.note is string && data.note.size() < 500 &&
             (data.timestamp is timestamp || data.timestamp is number) &&
             data.type in ['transfer', 'reward', 'system'] &&
             (data.confirmed == true || data.confirmed == false);
    }

    match /users/{userId} {
      allow read: if true; // Public profiles for now to allow selection
      allow create: if isValidUser(request.resource.data);
      allow update: if isAdmin() || 
                       // Allow atomic updates to balance/value from transactions
                       (request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'unconfirmedValue', 'cumulativeValue', 'level']));
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if true; // Everyone can see the feed
      allow create: if isValidTransaction(request.resource.data);
      allow update: if resource.data.confirmed == false && 
                      request.resource.data.confirmed == true && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmed']);
      allow delete: if isAdmin();
    }
  }
}
