rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string
    //   - name: string
    //   - avatar: string
    //   - cumulativeValue: number
    //   - unconfirmedValue: number
    //   - level: number
    //   - balance: number
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - id: string
    //   - fromId: string
    //   - toId: string
    //   - amount: number
    //   - note: string
    //   - timestamp: number
    //   - confirmed: boolean
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return (!('id' in data) || data.id is string) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() < 200)) &&
             (!('cumulativeValue' in data) || (data.cumulativeValue is number && data.cumulativeValue >= 0)) &&
             (!('unconfirmedValue' in data) || (data.unconfirmedValue is number && data.unconfirmedValue >= 0)) &&
             (!('level' in data) || (data.level is number && data.level >= 1)) &&
             (!('balance' in data) || (data.balance is number && data.balance >= 0));
    }

    function isValidTransaction(data) {
      return (!('id' in data) || data.id is string) &&
             (!('fromId' in data) || data.fromId is string) &&
             (!('toId' in data) || data.toId is string) &&
             (!('fromName' in data) || data.fromName is string) &&
             (!('toName' in data) || data.toName is string) &&
             (!('amount' in data) || (data.amount is number && data.amount > 0)) &&
             (!('note' in data) || (data.note is string && data.note.size() < 1000)) &&
             (!('timestamp' in data) || data.timestamp is number) &&
             (!('type' in data) || data.type is string) &&
             (!('confirmed' in data) || data.confirmed is bool);
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /transactions/{transactionId} {
      allow read, write: if true;
    }
  }
}
