{
  "entities": {
    "User": {
      "title": "User",
      "description": "시스템 사용자 정보 및 토큰 잔액",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "cumulativeValue": { "type": "number" },
        "unconfirmedValue": { "type": "number" },
        "level": { "type": "number" },
        "balance": { "type": "number" }
      },
      "required": ["id", "name", "avatar", "cumulativeValue", "unconfirmedValue", "level", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "토큰 거래 내역",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "amount": { "type": "number" },
        "note": { "type": "string" },
        "timestamp": { "type": "number" },
        "confirmed": { "type": "boolean" }
      },
      "required": ["id", "fromId", "toId", "amount", "note", "timestamp", "confirmed"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "사용자 프로필 및 잔액 정보"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "모든 토큰 거래 기록"
    }
  }
}
